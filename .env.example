# ============================================================
# AASHA AI — Environment Configuration
# Annanth Aasha Foundation
# Copy this file to .env and fill in your values.
# ============================================================

# ── AI / LLM ────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=4096

# ── Application ─────────────────────────────────────────────
APP_ENV=development
APP_NAME=AASHA AI TEAS
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# ── Backend ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# ── Database ────────────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/aasha
POSTGRES_POOL_SIZE=10

# ── Cache ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Storage ─────────────────────────────────────────────────
VECTOR_DB_PATH=./data/vector
ASSET_STORE_PATH=./assets
DATA_PATH=./data

# ── NGO execution context ───────────────────────────────────
CENTRE_MODE=ground_execution
ORGANIZATION_NAME=Annanth Aasha Foundation
CENTRE_ID=aasha-centre-01
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,ta,hi,te

# ── Rewards ─────────────────────────────────────────────────
AASHA_COIN_ENABLED=true
XP_PER_NODE=10
COIN_PER_ASSESSMENT_PASS=5

# ── Optional: Production deployment ─────────────────────────
AWS_REGION=ap-south-1
S3_BUCKET=
S3_ASSET_PREFIX=aasha/assets/
VERCEL_PROJECT=aasha-ai-teas

# ── Telegram Ingestion ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=

